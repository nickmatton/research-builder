.env
.venv/
__pycache__/
*.pyc
*.egg-info/
dist/
build/
.pytest_cache/

# Large binary artifacts from pipeline runs
*.pt

# OS cruft
.DS_Store

# Runtime state from harness runs
canonical_spec/
phases/
logs/
context/
report/

# Backups from prior runs
*.bak.*/
canonical_spec.bak.*/
phases.bak.*/

# Old harness run snapshots (4GB+ of timestamped run dirs from the harness era).
# The harness source itself lives at custom-harness/ (tracked); this is just runtime junk.
.archive/

# Per-paper scratch dirs (pre-migration; replaced by papers/<slug>/ later)
attentionisallyouneed/

# Per-paper run outputs at root (slugged directories produced by the harness)
runs/

# Vite/React frontend build artifacts
custom-harness/frontend/node_modules/
custom-harness/frontend/dist/

# Local FastAPI app caches
custom-harness/web/.cache/

# Bundled example run outputs (kept tracked: examples/test_paper_run/)
custom-harness/examples/*/runs/

# OS cruft
.DS_Store
